pipelines:
  generate:
    defaults:
      size: 1536x1024
      quality: low
    stages:
      - name: brainstorm
        output: text
        prompt: prompts/example/gen_meta.md
      - name: render
        output: image
        prompt: prompts/example/gen_image.md

  remix:
    defaults:
      size: 1024x1024
      quality: low
    stages:
      - name: stylize
        output: image
        prompt: prompts/example/stylize.md
        image_input: _source

  tag:
    defaults:
      max_tags: 10
    stages:
      - name: descriptor
        output: text
        prompt: prompts/example/descriptor.md
        image_input: _source
      - name: tagger
        output: text
        prompt: prompts/example/tagger.md
