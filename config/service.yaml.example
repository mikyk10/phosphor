pipelines:
  dinner:
    defaults:
      size: 800x480
    stages:
      - name: context
        output: text
        prompt: config/prompts/examples/dinner_data.md
      - name: suggest
        output: text
        prompt: config/prompts/examples/dinner_suggest.md
      - name: render
        output: image
        prompt: config/prompts/examples/dinner_render.md

  dashboard:
    defaults:
      size: 800x480
    stages:
      - name: data
        output: text
        prompt: config/prompts/examples/dashboard_data.md
      - name: render
        output: image
        prompt: config/prompts/examples/dashboard_render.md

  generate:
    defaults:
      size: 1536x1024
      quality: low
    stages:
      - name: brainstorm
        output: text
        prompt: config/prompts/examples/generate/meta.md
      - name: render
        output: image
        prompt: config/prompts/examples/generate/image.md

  remix:
    defaults:
      size: 1024x1024
      quality: low
    stages:
      - name: stylize
        output: image
        prompt: config/prompts/examples/remix/stylize.md
        image_input: _source

  tag:
    defaults:
      max_tags: 10
    stages:
      - name: descriptor
        output: text
        prompt: config/prompts/examples/tag/descriptor.md
        image_input: _source
      - name: tagger
        output: text
        prompt: config/prompts/examples/tag/tagger.md

  proverbs:
    defaults:
      size: 1536x1024
      quality: low
    stages:
      - name: proverb-text
        output: text
        prompt: config/prompts/examples/proverb/text.md
      - name: proverb-image
        output: image
        prompt: config/prompts/examples/proverb/image.md

  surreal:
    defaults:
      size: 1536x1024
      quality: low
    stages:
      - name: brainstorm
        output: text
        prompt: config/prompts/examples/generate/brainstorm.md
      - name: refine
        output: text
        prompt: config/prompts/examples/surreal/refine.md
      - name: generate
        output: image
        prompt: config/prompts/examples/surreal/generate.md

  nordic:
    defaults:
      size: 1536x1024
      quality: low
    stages:
      - name: brainstorm
        output: text
        prompt: config/prompts/examples/generate/brainstorm.md
      - name: refine
        output: text
        prompt: config/prompts/examples/nordic/refine.md
      - name: generate
        output: image
        prompt: config/prompts/examples/nordic/generate.md
