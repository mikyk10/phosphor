pipelines:
  generate:
    defaults:
      size: 1536x1024
      quality: low
    stages:
      - name: brainstorm
        output: text
        prompt: config/prompts/examples/gen_meta.md
      - name: render
        output: image
        prompt: config/prompts/examples/gen_image.md

  remix:
    defaults:
      size: 1024x1024
      quality: low
    stages:
      - name: stylize
        output: image
        prompt: config/prompts/examples/stylize.md
        image_input: _source

  tag:
    defaults:
      max_tags: 10
    stages:
      - name: descriptor
        output: text
        prompt: config/prompts/examples/descriptor.md
        image_input: _source
      - name: tagger
        output: text
        prompt: config/prompts/examples/tagger.md
