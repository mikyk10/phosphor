port: 8082
log_level: DEBUG

database:
  dsn: ":memory:"           # default: in-memory (stateless)
  # dsn: ./phosphor.db       # debug: persistent file

ai:
  request_timeout_sec: 120
  max_retries: 3
  providers:
    openai:
      endpoint: https://api.openai.com/v1
      api_key: "${OPENAI_API_KEY}"
    # ollama:
    #   endpoint: http://localhost:11434/v1
